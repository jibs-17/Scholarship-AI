# --- Next.js (this file / Vercel "Environment Variables") ---
# Convex client URL — must match the deployment you use (dev vs prod).
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Optional: canonical URL for OG tags. Vercel sets VERCEL_URL; app falls back to it.
NEXT_PUBLIC_SITE_URL=

# --- Convex dashboard (Settings → Environment Variables, production) ---
# EXA_API_KEY=       optional web search context
# OPENAI_API_KEY=    required for AI-matched scholarships (demo fallback if unset)
# Redeploy after changes: npm run convex:deploy
